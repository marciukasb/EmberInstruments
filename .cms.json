{
  "collections": [
    {
      "name": "Blog Posts",
      "folder": "app/_data/_blog",
      "imageFolder": "public/images",
      "imageUrlPrefix": "/images",
      "fields": [
        { "name": "title", "type": "text" },
        { "name": "summary", "type": "textarea" },
        { "name": "topic", "type": "text" },
        { "name": "date", "type": "date" },
        { "name": "thumbnail", "type": "image" },
        { "name": "body", "type": "markdown" }
      ]
    }
  ]
}
